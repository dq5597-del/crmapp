# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://你的project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key

# Supabase service role（av-shop 發佈後回寫用，勿外流）
SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# Anthropic（名片 OCR 用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# av-shop.com（WooCommerce）產品同步
# 金鑰：WooCommerce → 設定 → 進階 → REST API 金鑰 →「CRM 產品同步」
# ============================================================
WC_STORE_URL=https://av-shop.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 網站發佈後回寫 CRM 的驗證字串（自訂，av-shop 端要填一樣的）
WC_WEBHOOK_SECRET=請自訂一組長字串
